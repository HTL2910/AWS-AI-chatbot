.PHONY: summary summary-view summary-list summary-search summary-clean

# Generate new session summary
summary:
	@echo "📋 Generating session summary..."
	@python3 generate_session_summary.py

# View latest summary
summary-view:
	@echo "📋 Latest session summary:"
	@./session-summary.sh view

# List all summaries
summary-list:
	@echo "📋 All session summaries:"
	@./session-summary.sh list

# Search summaries
summary-search:
	@echo "📋 Search summaries (usage: make summary-search KEYWORD=<keyword>)"
	@python3 .session-history/search.py "$(KEYWORD)"

# Clean old summaries (keep last 20)
summary-clean:
	@echo "🧹 Cleaning old summaries..."
	@ls -t .session-history/SUMMARY_*.md | tail -n +21 | xargs rm -f
	@echo "✅ Done"

# Show summary help
summary-help:
	@cat .session-history/USAGE_GUIDE.md
