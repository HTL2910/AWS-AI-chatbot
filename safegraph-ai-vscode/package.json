{
  "name": "safegraph-ai",
  "displayName": "Safegraph AI v0.16.0",
  "description": "Multi-agent AI development platform with autonomous coding, artifact verification, and project-wide refactoring.",
  "repository": {
    "type": "git",
    "url": "https://github.com/safegraph-ai/safegraph-ai-vscode.git"
  },
  "version": "0.16.0",
  "publisher": "safegraph",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:safegraph.chatView",
    "onCommand:safegraph.openChat",
    "onCommand:safegraph.setBedrockApiKey",
    "onCommand:safegraph.checkBedrockApiKey",
    "onCommand:safegraph.openLog",
    "onCommand:safegraph.moveChatRight",
    "onCommand:safegraph.inlineEdit",
    "onCommand:safegraph.showHistory",
    "onCommand:safegraph.openAgentManager",
    "onCommand:safegraph.openArtifactViewer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "safegraph.setBedrockApiKey",
        "title": "Safegraph AI: Set Bedrock API Key"
      },
      {
        "command": "safegraph.checkBedrockApiKey",
        "title": "Safegraph AI: Check Bedrock API Key Source"
      },
      {
        "command": "safegraph.openLog",
        "title": "Safegraph AI: Open Log"
      },
      {
        "command": "safegraph.openAuditLog",
        "title": "Safegraph AI: Open Audit Log"
      },
      {
        "command": "safegraph.moveChatRight",
        "title": "Safegraph AI: Move Chat To Right Sidebar"
      },
      {
        "command": "safegraph.openChat",
        "title": "Safegraph AI: Open Chat"
      },
      {
        "command": "safegraph.inlineEdit",
        "title": "Safegraph AI: Inline Edit"
      },
      {
        "command": "safegraph.inlineAccept",
        "title": "Safegraph AI: Accept Inline Edit"
      },
      {
        "command": "safegraph.inlineReject",
        "title": "Safegraph AI: Reject Inline Edit"
      },
      {
        "command": "safegraph.showHistory",
        "title": "Safegraph AI: Show Task History"
      },
      {
        "command": "safegraph.openAgentManager",
        "title": "Safegraph AI: Open Agent Manager"
      },
      {
        "command": "safegraph.openArtifactViewer",
        "title": "Safegraph AI: Open Artifact Viewer"
      }
    ],
    "keybindings": [
      {
        "command": "safegraph.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "safegraph.inlineAccept",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && safegraph.inlineActive"
      },
      {
        "command": "safegraph.inlineReject",
        "key": "escape",
        "mac": "escape",
        "when": "editorTextFocus && safegraph.inlineActive"
      }
    ],
    "configuration": {
      "title": "Safegraph AI v0.16.0",
      "properties": {
        "safegraph.autoRun": {
          "type": "string",
          "enum": [
            "off",
            "safe",
            "ask"
          ],
          "default": "safe",
          "description": "Auto-run commands in VS Code Terminal. 'safe' runs allowlisted commands automatically and asks for the rest."
        },
        "safegraph.region": {
          "type": "string",
          "default": "ap-southeast-1",
          "description": "AWS region for Bedrock Runtime."
        },
        "safegraph.modelId": {
          "type": "string",
          "default": "arn:aws:bedrock:ap-southeast-1:510900713068:application-inference-profile/jxsjbl4xo623",
          "description": "Bedrock model identifier or inference profile ARN."
        },
        "safegraph.repositoryRag.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Include local repository RAG context for each chat request."
        },
        "safegraph.repositoryRag.maxFiles": {
          "type": "number",
          "default": 800,
          "minimum": 50,
          "maximum": 5000,
          "description": "Maximum source files to index for local repository RAG."
        },
        "safegraph.repositoryRag.maxChunks": {
          "type": "number",
          "default": 6,
          "minimum": 1,
          "maximum": 40,
          "description": "Maximum retrieved repository chunks included in each prompt."
        },
        "safegraph.repositoryRag.maxChars": {
          "type": "number",
          "default": 10000,
          "minimum": 2000,
          "maximum": 80000,
          "description": "Maximum characters of repository RAG context included in each prompt."
        },
        "safegraph.vectorRag.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable optional semantic vector retrieval for repository context. Disabled by default until a sidecar provider is configured."
        },
        "safegraph.vectorRag.provider": {
          "type": "string",
          "enum": [
            "disabled",
            "turbovec-sidecar"
          ],
          "default": "disabled",
          "description": "Semantic vector retrieval provider. turbovec-sidecar is planned for compressed local vector RAG."
        },
        "safegraph.vectorRag.embeddingProvider": {
          "type": "string",
          "enum": [
            "bedrock",
            "local",
            "external"
          ],
          "default": "bedrock",
          "description": "Embedding source for future vector RAG indexing."
        },
        "safegraph.vectorRag.dim": {
          "type": "number",
          "default": 1536,
          "minimum": 8,
          "maximum": 8192,
          "description": "Embedding dimension for future vector RAG indexing."
        },
        "safegraph.vectorRag.bitWidth": {
          "type": "number",
          "enum": [
            2,
            4
          ],
          "default": 4,
          "description": "TurboQuant bit width for future turbovec compressed indexes."
        },
        "safegraph.vectorRag.maxResults": {
          "type": "number",
          "default": 12,
          "minimum": 1,
          "maximum": 80,
          "description": "Maximum semantic vector retrieval results before reranking and prompt compaction."
        },
        "safegraph.agent.maxFixLoops": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 3,
          "description": "Maximum autonomous edit-test-fix loops after Safegraph applies a diff. Only safe allowlisted commands auto-run."
        },
        "safegraph.mcp.codegraph.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Start the optional external CodeGraph MCP server with npx for repository analysis. Disabled by default to avoid slow or failing network-backed startup."
        },
        "safegraph.agent.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable multi-agent orchestration system for complex tasks."
        },
        "safegraph.agent.maxConcurrent": {
          "type": "number",
          "default": 3,
          "minimum": 1,
          "maximum": 10,
          "description": "Maximum number of concurrent agents running."
        },
        "safegraph.artifact.autoGenerate": {
          "type": "boolean",
          "default": true,
          "description": "Automatically generate artifacts for task verification."
        },
        "safegraph.completion.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AI-powered inline code completion."
        },
        "safegraph.completion.triggerMode": {
          "type": "string",
          "enum": [
            "automatic",
            "manual"
          ],
          "default": "automatic",
          "description": "When to trigger inline completion suggestions."
        },
        "safegraph.multifile.dependencyAnalysis": {
          "type": "boolean",
          "default": true,
          "description": "Enable dependency analysis for multi-file editing."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "safegraph",
          "title": "Safegraph AI v0.16.0",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "safegraph": [
        {
          "id": "safegraph.chatView",
          "name": "Chat",
          "type": "webview"
        },
        {
          "id": "safegraph.agentManager",
          "name": "Agent Manager",
          "type": "webview",
          "when": "safegraph.agent.enabled"
        },
        {
          "id": "safegraph.artifactViewer",
          "name": "Artifacts",
          "type": "webview",
          "when": "safegraph.artifact.autoGenerate"
        }
      ]
    }
  },
  "scripts": {
    "build:webview": "cd webview-ui && npm run build",
    "build:ext": "tsc -p .",
    "typecheck": "tsc -p . --noEmit",
    "test": "jest --watchman=false --coverage",
    "test:ci": "jest --watchman=false --runInBand --coverage",
    "build": "npm run build:webview && npm run build:ext",
    "watch": "tsc -p . -w",
    "bump": "node scripts/bump-version.js",
    "package": "npm run build && node scripts/package-vsix.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.0",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/axios": "^0.14.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "jest": "^29.7.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^7.10.0"
  }
}
