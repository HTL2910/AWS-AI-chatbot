{
  "name": "safegraph-ai",
  "displayName": "Safegraph AI v0.8.0",
  "description": "MVP sidebar AI chat with local code-graph context and Bedrock integration.",
  "repository": {
    "type": "git",
    "url": "https://github.com/safegraph-ai/safegraph-ai-vscode.git"
  },
  "version": "0.8.0",
  "publisher": "safegraph",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:safegraph.chatView",
    "onCommand:safegraph.openChat",
    "onCommand:safegraph.setBedrockApiKey",
    "onCommand:safegraph.checkBedrockApiKey",
    "onCommand:safegraph.openLog",
    "onCommand:safegraph.moveChatRight",
    "onCommand:safegraph.inlineEdit"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "safegraph.setBedrockApiKey",
        "title": "Safegraph AI: Set Bedrock API Key"
      },
      {
        "command": "safegraph.checkBedrockApiKey",
        "title": "Safegraph AI: Check Bedrock API Key Source"
      },
      {
        "command": "safegraph.openLog",
        "title": "Safegraph AI: Open Log"
      },
      {
        "command": "safegraph.moveChatRight",
        "title": "Safegraph AI: Move Chat To Right Sidebar"
      },
      {
        "command": "safegraph.openChat",
        "title": "Safegraph AI: Open Chat"
      },
      {
        "command": "safegraph.inlineEdit",
        "title": "Safegraph AI: Inline Edit"
      },
      {
        "command": "safegraph.inlineAccept",
        "title": "Safegraph AI: Accept Inline Edit"
      },
      {
        "command": "safegraph.inlineReject",
        "title": "Safegraph AI: Reject Inline Edit"
      }
    ],
    "keybindings": [
      {
        "command": "safegraph.inlineEdit",
        "key": "ctrl+k",
        "mac": "cmd+k",
        "when": "editorTextFocus && !editorReadonly"
      },
      {
        "command": "safegraph.inlineAccept",
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "when": "editorTextFocus && safegraph.inlineActive"
      },
      {
        "command": "safegraph.inlineReject",
        "key": "escape",
        "mac": "escape",
        "when": "editorTextFocus && safegraph.inlineActive"
      }
    ],
    "configuration": {
      "title": "Safegraph AI v0.8.0",
      "properties": {
        "safegraph.autoRun": {
          "type": "string",
          "enum": [
            "off",
            "safe",
            "ask"
          ],
          "default": "safe",
          "description": "Auto-run commands in VS Code Terminal. 'safe' runs allowlisted commands automatically and asks for the rest."
        },
        "safegraph.region": {
          "type": "string",
          "default": "ap-southeast-1",
          "description": "AWS region for Bedrock Runtime."
        },
        "safegraph.modelId": {
          "type": "string",
          "default": "arn:aws:bedrock:ap-southeast-1:510900713068:application-inference-profile/jxsjbl4xo623",
          "description": "Bedrock model identifier or inference profile ARN."
        },
        "safegraph.repositoryRag.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Include local repository RAG context for each chat request."
        },
        "safegraph.repositoryRag.maxFiles": {
          "type": "number",
          "default": 800,
          "minimum": 50,
          "maximum": 5000,
          "description": "Maximum source files to index for local repository RAG."
        },
        "safegraph.repositoryRag.maxChunks": {
          "type": "number",
          "default": 10,
          "minimum": 1,
          "maximum": 40,
          "description": "Maximum retrieved repository chunks included in each prompt."
        },
        "safegraph.repositoryRag.maxChars": {
          "type": "number",
          "default": 18000,
          "minimum": 2000,
          "maximum": 80000,
          "description": "Maximum characters of repository RAG context included in each prompt."
        },
        "safegraph.agent.maxFixLoops": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "maximum": 3,
          "description": "Maximum autonomous edit-test-fix loops after Safegraph applies a diff. Only safe allowlisted commands auto-run."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "safegraph",
          "title": "Safegraph AI v0.8.0",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "safegraph": [
        {
          "id": "safegraph.chatView",
          "name": "Chat",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build:webview": "cd webview-ui && npm run build",
    "build:ext": "tsc -p .",
    "build": "npm run build:webview && npm run build:ext",
    "watch": "tsc -p . -w",
    "bump": "node scripts/bump-version.js",
    "package": "npm run build && node scripts/package-vsix.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/vscode": "^1.90.0"
  }
}
